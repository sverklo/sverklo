{
  "name": "@nicenemo/codesearch-mcp",
  "version": "0.1.0",
  "description": "Local-first code search MCP server with AST parsing, semantic search, and PageRank ranking",
  "type": "module",
  "bin": {
    "codesearch-mcp": "./dist/bin/codesearch-mcp.js"
  },
  "main": "./dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/codesearch-mcp.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "code-search",
    "tree-sitter",
    "semantic-search",
    "claude-code",
    "cursor",
    "ai-coding"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.0",
    "ignore": "^7.0.0",
    "onnxruntime-node": "^1.21.0",
    "web-tree-sitter": "^0.24.7",
    "xxhash-wasm": "^1.1.0",
    "gpt-tokenizer": "^2.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
